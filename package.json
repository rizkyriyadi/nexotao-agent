{
  "name": "nexotao",
  "version": "0.10.0",
  "description": "A local, single-user coding agent with a web UI, powered by your Nexotao API key. Install, run `nexotao`, and start building on your own machine.",
  "keywords": [
    "nexotao",
    "coding-agent",
    "ai",
    "claude",
    "agent",
    "local",
    "cli",
    "developer-tools"
  ],
  "homepage": "https://github.com/rizkyriyadi/nexotao-agent#readme",
  "bugs": {
    "url": "https://github.com/rizkyriyadi/nexotao-agent/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rizkyriyadi/nexotao-agent.git"
  },
  "license": "MIT",
  "author": "Rizky Riyadi",
  "type": "module",
  "engines": {
    "node": ">=18.18"
  },
  "bin": {
    "nexotao": "bin/nexotao.mjs"
  },
  "files": [
    "bin",
    ".next",
    "public",
    "next.config.mjs"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "nexotao": "node bin/nexotao.mjs",
    "lint": "eslint",
    "prepublishOnly": "npm run lint && npm test && npm run build",
    "test": "tsx --test tests/*.test.ts",
    "test:e2e": "node scripts/e2e-run.mjs",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/release-smoke.mjs",
    "audit:a11y": "node scripts/a11y-audit.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.4",
    "@radix-ui/react-checkbox": "^1.3.8",
    "@radix-ui/react-dialog": "^1.1.20",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.4",
    "@radix-ui/react-tabs": "^1.1.18",
    "@radix-ui/react-tooltip": "^1.2.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.25.0",
    "next": "16.2.11",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sql.js": "^1.4.11",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "puppeteer-core": "^25.3.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  },
  "overrides": {
    "sharp": ">=0.35.3",
    "postcss": ">=8.5.21"
  }
}
